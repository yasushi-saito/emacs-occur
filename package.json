{
  "name": "emacs-occur",
  "displayName": "Emacs Occur",
  "description": "Emacs occur mode in VS Code",
  "version": "0.0.1",
  "publisher": "saito",
  "engines": {
    "vscode": "^1.60.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:emacs-occur.occurtext"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "emacs-occur.occurtext",
        "title": "Occur Text",
        "category": "Emacs Occur"
      },
      {
        "command": "emacs-occur.jump",
        "title": "Jump to Occur Match",
        "category": "Emacs Occur"
      }
    ],
    "keybindings": [
      {
        "command": "emacs-occur.jump",
        "key": "enter",
        "when": "emacs-occur.active"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/suite/extension.test.js"
  },
  "devDependencies": {
    "@types/mocha": "^9.1.1",
    "@types/node": "^18.0.3",
    "@types/vscode": "^1.60.0",
    "@vscode/test-electron": "^2.2.0",
    "mocha": "^10.0.0",
    "typescript": "^4.7.4"
  }
}
