{
  "name": "emacs-occur",
  "displayName": "Emacs Occur",
  "description": "Emacs occur mode in VS Code",
  "version": "0.1.0",
  "publisher": "YasushiSaito",
  "engines": {
    "vscode": "^1.60.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/yasushi-saito/emacs-occur"
  },
  "categories": [
    "Other"
  ],
  "license": "Apache",
  "keywords": [
    "emacs",
    "occur"
  ],
  "activationEvents": [
    "onCommand:emacs-occur.occurtext"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "emacs-occur.occurRegex",
        "title": "Occur Regex",
        "category": "Emacs Occur"
      },
      {
        "command": "emacs-occur.jump",
        "title": "Jump to Occur Match",
        "category": "Emacs Occur"
      },
      {
        "command": "emacs-occur.quit",
        "title": "Quit Occur",
        "category": "Emacs Occur"
      }
    ],
    "keybindings": [
      {
        "command": "emacs-occur.jump",
        "key": "enter",
        "when": "emacs-occur.active"
      },
      {
        "command": "emacs-occur.jump",
        "key": "ctrl+m",
        "when": "emacs-occur.active"
      },
      {
        "command": "emacs-occur.quit",
        "key": "q",
        "when": "emacs-occur.active"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile",
    "test": "node ./out/test/runTest.js",
    "prettier": "prettier --write ."
  },
  "devDependencies": {
    "@types/mocha": "^9.1.1",
    "@types/node": "^18.0.3",
    "@types/vscode": "^1.60.0",
    "@vscode/test-electron": "^2.2.0",
    "glob": "^13.0.6",
    "mocha": "^10.0.0",
    "prettier": "^3.8.4",
    "typescript": "^4.7.4"
  }
}
